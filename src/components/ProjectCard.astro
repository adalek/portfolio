---
interface Props {
  title: string;
  href: string;
  cover: string;
  year: number;
  category: string;
  summary: string;
  tools: string[];
}

const { title, href, cover, year, category, summary, tools } = Astro.props;
const filterTags = [category, ...tools].map((tag) => tag.toLowerCase());
const isPdfCover = cover.toLowerCase().endsWith('.pdf');
const hasImageCover = cover.length > 0 && !isPdfCover;
---

<article class="project-card" data-project-card data-tags={filterTags.join('|')}>
  <a href={href} aria-label={`View ${title}`}>
    <div class="image-wrap">
      {
        isPdfCover || !hasImageCover ? (
          <div class="document-cover" aria-hidden="true">
            <span>{isPdfCover ? 'PDF' : category}</span>
            <strong>{title}</strong>
          </div>
        ) : (
          <img src={cover} alt="" loading="lazy" />
        )
      }
    </div>
    <div class="card-copy">
      <p>{year} / {category}</p>
      <h2>{title}</h2>
      <span>{summary}</span>
      <ul class="tag-list">
        {tools.slice(0, 4).map((tool) => <li>{tool}</li>)}
      </ul>
    </div>
  </a>
</article>

<style>
  .project-card {
    border-top: 1px solid var(--line);
  }

  .project-card a {
    display: grid;
    grid-template-columns: minmax(220px, 38%) 1fr;
    gap: 26px;
    padding: 24px 0;
  }

  .image-wrap {
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background: var(--media-bg);
  }

  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 260ms ease;
  }

  .project-card:hover img {
    transform: scale(1.035);
  }

  .document-cover {
    display: grid;
    align-content: space-between;
    width: 100%;
    height: 100%;
    padding: 18px;
    background:
      linear-gradient(135deg, rgba(214, 255, 98, 0.16), transparent 42%),
      linear-gradient(180deg, var(--panel), var(--bg));
    color: var(--text);
  }

  .document-cover span {
    width: max-content;
    border: 1px solid var(--line);
    padding: 5px 7px;
    color: var(--muted);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.12em;
  }

  .document-cover strong {
    max-width: 90%;
    font-size: clamp(20px, 3vw, 34px);
    line-height: 0.98;
    text-transform: uppercase;
  }

  .card-copy {
    display: grid;
    align-content: start;
    gap: 12px;
  }

  p {
    margin: 0;
    color: var(--muted);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h2 {
    margin: 0;
    font-size: clamp(28px, 5vw, 58px);
    line-height: 0.92;
    text-transform: uppercase;
  }

  span {
    max-width: 640px;
    color: var(--muted);
    font-size: 16px;
    line-height: 1.55;
  }

  @media (max-width: 760px) {
    .project-card a {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }
</style>
