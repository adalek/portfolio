---
interface MediaItem {
  type: 'image' | 'video' | 'pdf';
  src: string;
  caption?: string;
}

interface Props {
  items: MediaItem[];
}

const { items } = Astro.props;
---

{
  items.length > 0 && (
    <section class="media-section" aria-label="Project media">
      {items.map((item) => (
        <figure class={item.type}>
          {item.type === 'image' && <img src={item.src} alt={item.caption ?? ''} loading="lazy" />}
          {item.type === 'video' && (
            <div class="video-frame">
              <iframe src={item.src} title={item.caption ?? 'Project video'} allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>
            </div>
          )}
          {item.type === 'pdf' && (
            <div class="pdf-card">
              <div class="pdf-copy">
                <p>PDF Documentation</p>
                <h3>{item.caption ?? 'Project document'}</h3>
                <a class="pdf-link" href={item.src} target="_blank" rel="noreferrer">
                  Open Fullscreen
                </a>
              </div>
              <object data={item.src} type="application/pdf" aria-label={item.caption ?? 'PDF preview'}>
                <a class="pdf-fallback" href={item.src} target="_blank" rel="noreferrer">Open PDF</a>
              </object>
            </div>
          )}
          {item.caption && item.type !== 'pdf' && <figcaption>{item.caption}</figcaption>}
        </figure>
      ))}
    </section>
  )
}

<style>
  .media-section {
    display: grid;
    gap: 28px;
    margin-top: 48px;
  }

  figure {
    margin: 0;
  }

  img {
    width: 100%;
    max-height: 760px;
    object-fit: contain;
    background: #111;
  }

  figcaption {
    margin-top: 10px;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.5;
  }

  .video-frame {
    aspect-ratio: 16 / 9;
    background: #111;
  }

  iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }

  .pdf-link {
    display: inline-flex;
    border: 1px solid var(--line);
    padding: 12px 16px;
    color: white;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .pdf-card {
    display: grid;
    grid-template-columns: minmax(280px, 38%) 1fr;
    min-height: 520px;
    border: 1px solid var(--line);
    background: #101010;
  }

  .pdf-copy {
    display: grid;
    align-content: start;
    gap: 18px;
    padding: 28px;
    min-width: 0;
  }

  .pdf-copy p {
    margin: 0;
    color: var(--muted);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .pdf-copy h3 {
    margin: 0;
    max-width: 100%;
    font-size: clamp(22px, 2.8vw, 34px);
    line-height: 1.08;
    text-transform: uppercase;
    overflow-wrap: anywhere;
    word-break: normal;
  }

  object {
    width: 100%;
    height: 100%;
    min-height: 520px;
    border: 0;
    background: #1a1a1a;
  }

  .pdf-fallback {
    display: grid;
    height: 100%;
    min-height: 360px;
    place-items: center;
    color: white;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  @media (max-width: 780px) {
    .pdf-card {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .pdf-copy h3 {
      font-size: clamp(21px, 7vw, 32px);
    }

    object {
      min-height: 420px;
    }
  }
</style>
