---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About / Xuwen Dong" description="About Xuwen Dong, a technical artist and game designer working across interactive media, games, visual arts, and sound.">
  <main class="page-shell">
    <section class="narrow">
      <p class="eyebrow">About</p>
      <h1 class="section-title">Xuwen Dong</h1>
      <div class="about-copy">
        <p>Xuwen Dong is a technical artist and game designer working across real-time graphics, interactive systems, games, creative coding, visual arts, and sound.</p>
        <p>The portfolio focuses on playable work, visual process, technical breakdowns, and production evidence for recruitment. Selected projects highlight both final outcomes and the decisions behind them: tools, roles, constraints, prototypes, and iteration.</p>
        <p>Contact: <a href="mailto:s5803453@bournemouth.ac.uk">s5803453@bournemouth.ac.uk</a></p>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .about-copy {
    margin-top: 40px;
  }

  p {
    color: var(--muted);
    font-size: clamp(19px, 3vw, 28px);
    line-height: 1.55;
  }

  a {
    color: var(--text);
    text-decoration: underline;
  }
</style>
