---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeFeatureLink from '../components/HomeFeatureLink.astro';

const projects = (await getCollection('projects'))
  .filter((project) => project.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const fallbackBackground = '/assets/GIF1.gif';
const getUsableBackground = (background?: string, cover = '') => {
  const source = background || cover;
  if (!source || source.toLowerCase().endsWith('.pdf')) return fallbackBackground;
  return source;
};

const defaultBackground = getUsableBackground(projects[0]?.data.background, projects[0]?.data.cover);
---

<BaseLayout title="Xuwen Dong / Portfolio" description="A portfolio of technical art, games, creative coding, visual arts, and process notes.">
  <main class="home">
    <div class="home-bg">
      <img src={defaultBackground} alt="" data-home-bg data-fallback-bg={fallbackBackground} />
      <div class="shade"></div>
    </div>

    <section class="home-content" aria-label="Featured work">
      <div class="intro">
        <p>Technical Artist / Game Designer / Creative Technologist</p>
      </div>

      {projects.map((project, index) => (
        <HomeFeatureLink
          title={project.data.title}
          summary={project.data.summary}
          href={`/work/${project.id}`}
          background={getUsableBackground(project.data.background, project.data.cover)}
          align={index % 2 === 0 ? 'left' : 'right'}
        />
      ))}

      <HomeFeatureLink
        title="Work Archive"
        summary="Browse projects by games, technical art, creative coding, visual arts, and sound."
        href="/work"
        background="/assets/GIF1.gif"
        align="right"
      />
    </section>
  </main>

  <script>
    const bg = document.querySelector('[data-home-bg]');
    const links = document.querySelectorAll('[data-bg]');

    if (bg instanceof HTMLImageElement) {
      bg.addEventListener('error', () => {
        const fallback = bg.getAttribute('data-fallback-bg');
        if (fallback && bg.src !== new URL(fallback, window.location.href).href) {
          bg.src = fallback;
        }
      });
    }

    links.forEach((link) => {
      link.addEventListener('mouseenter', () => {
        const next = link.getAttribute('data-bg');
        if (bg instanceof HTMLImageElement && next) {
          bg.src = next;
        }
      });
    });
  </script>
</BaseLayout>

<style>
  .home {
    position: relative;
    isolation: isolate;
    min-height: 100vh;
    padding: 120px 42px 54px;
  }

  .home-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    background: #050505;
    pointer-events: none;
  }

  .home-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.9;
  }

  .shade {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(90deg, rgba(0, 0, 0, 0.46), rgba(0, 0, 0, 0.12), rgba(0, 0, 0, 0.52)),
      linear-gradient(180deg, rgba(0, 0, 0, 0.22), transparent 34%, rgba(0, 0, 0, 0.28));
  }

  .home-content {
    position: relative;
    z-index: 2;
    display: grid;
    gap: 6px;
    width: min(1360px, 100%);
    margin: 0 auto;
  }

  .intro {
    max-width: 520px;
    margin-bottom: 28px;
  }

  .intro p {
    margin: 0;
    color: rgba(255, 255, 255, 0.74);
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.16em;
    line-height: 1.55;
    text-transform: uppercase;
  }

  @media (max-width: 720px) {
    .home {
      padding: 98px 18px 42px;
    }
  }
</style>
